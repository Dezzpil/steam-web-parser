# Database credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=steam_parser
POSTGRES_PORT=5436

# Database connection
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}?schema=public"

STEAM_API_KEY=
STEAM_API_ONLINE_URL=https://api.steampowered.com/ISteamUserStats/GetNumberOfCurrentPlayers/v1
STEAM_STORE_APP_DETAILS_URL=https://store.steampowered.com/api/appdetails

# API server port
API_PORT=3000
API_BASE_URL=http://localhost:3000

# UI port
UI_PORT=8080

# Max messages queue length for crawl and price-online processes
CRAWL_MAX_MESSAGES=200
PRICE_ONLINE_MAX_MESSAGES=200

# Prisma configuration
# Uncomment the following line to enable query logging
# DEBUG="prisma:query"