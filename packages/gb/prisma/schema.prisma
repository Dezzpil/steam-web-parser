generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ProductGenre {
  id       Int       @id
  name     String
  Products Product[]
}

model ProductPlatform {
  id       Int       @id
  name     String
  products Product[]
}

model Product {
  id         Int     @id
  skuId      Int
  skuCode    String
  name       String
  type       String
  isPreorder Boolean

  Genres    ProductGenre[]
  Platforms ProductPlatform[]

  parentId Int?
}

model SimilarProduct {
  productId Int
  name      String
  skuId     Int

  @@unique([productId, skuId])
}
