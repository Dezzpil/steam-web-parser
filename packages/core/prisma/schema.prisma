// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppUrl {
  id        Int       @unique
  path      String
  fromAppId Int?
  createdAt DateTime  @default(now())
  grabbedAt DateTime?
  error     String?

  App App?
}

model App {
  id Int @unique

  title                 String
  linkToLogoImg         String
  descriptionMini       String
  releaseDate           String
  developers            String[]
  reviewsSummaryExplain String
  reviewsSummaryCount   Int      @default(0)
  genre                 String[]
  popularTags           String[]
  categories            String[]
  description           String
  linkToMoreLikeThis    String
  isDownloadableContent Boolean

  moreGrabbedAt DateTime?
  moreLen       Int?

  AppUrl AppUrl @relation(fields: [id], references: [id], onDelete: Cascade)

  // Добавляем отношения для связи многие-ко-многим
  leftRelations AppToApp[] @relation("LeftApp")
}

model AppToApp {
  leftId  Int
  rightId Int

  // Связываем с моделью App в обоих направлениях
  leftApp App @relation("LeftApp", fields: [leftId], references: [id], onDelete: Cascade)

  @@unique([leftId, rightId])
}
