// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppUrl {
  id        Int       @unique
  path      String
  fromAppId Int?
  createdAt DateTime  @default(now())
  grabbedAt DateTime?
  parsedAt  DateTime?
}

model App {
  id          Int      @unique
  title       String
  description String
  genre       String[]
  popularTags String[]
}

model MoreAppsLikeThis {
  thisId    Int
  anotherId Int

  @@unique([thisId, anotherId])
}
