// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client" // Custom path
}

datasource db {
  provider = "postgresql"
}

model AppUrl {
  id          Int       @unique
  path        String
  fromAppId   Int?
  createdAt   DateTime  @default(now())
  grabbedAt   DateTime?
  error       String?
  forMainLoop Boolean   @default(false)
  foundByTerm String?

  App App?
}

model App {
  id Int @unique

  title                 String
  linkToLogoImg         String
  descriptionMini       String
  releaseDate           String
  developers            String[]
  reviewsSummaryExplain String
  reviewsSummaryCount   Int      @default(0)
  genre                 String[]
  popularTags           String[]
  categories            String[]
  description           String
  linkToMoreLikeThis    String
  isDownloadableContent Boolean

  moreGrabbedAt DateTime?
  moreLen       Int?

  AppUrl AppUrl @relation(fields: [id], references: [id], onDelete: Cascade)

  updatedAt DateTime?

  Related AppToApp[]  @relation("LeftApp")
  Online  AppOnline[]
  Price   AppPrice[]

  lastOnline Int @default(0)
  lastPrice  Int @default(0)

  @@index([updatedAt])
}

model AppToApp {
  leftId  Int
  rightId Int

  // Связываем с моделью App в обоих направлениях
  leftApp App @relation("LeftApp", fields: [leftId], references: [id], onDelete: Cascade)

  @@unique([leftId, rightId])
}

model AppOnline {
  id        Int      @unique @default(autoincrement())
  appId     Int
  createdAt DateTime @default(now())

  value Int

  App App @relation(fields: [appId], references: [id], onDelete: Cascade)
}

model AppPrice {
  id        Int      @unique @default(autoincrement())
  appId     Int
  createdAt DateTime @default(now())

  currency         String
  initial          Int
  final            Int
  discount         Int
  initialFormatted String
  finalFormatted   String

  App App @relation(fields: [appId], references: [id], onDelete: Cascade)
}
